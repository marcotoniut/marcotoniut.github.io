#!/usr/bin/env bash
set -euo pipefail

# Reload direnv when core environment inputs change.
watch_file .env
watch_file .prototools

# Basic tooling checks used by local workflows.
if ! command -v proto >/dev/null 2>&1; then
  echo "direnv: proto is required but was not found in PATH" >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "direnv: pnpm is required but was not found in PATH" >&2
  exit 1
fi

# Load local environment variables when present.
if [[ -f .env ]]; then
  dotenv .env
fi
